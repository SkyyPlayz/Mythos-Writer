{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "outDir": "./dist",
    "baseUrl": "..",
    "paths": {}
  },
  "include": ["./*.ts", "../src/**/*.ts"],
  "exclude": ["../node_modules", "./dist"]
}
