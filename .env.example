ANTHROPIC_API_KEY=your_anthropic_api_key_here
PORT=3001

# Story API access control: use "demo" for local/demo installs or "token" for protected deployments.
STORY_API_ACCESS_MODE=demo
# Required when STORY_API_ACCESS_MODE=token. Keep server-side only: direct API clients use
# an Authorization: Bearer header; served browsers use an HttpOnly signed session cookie.
STORY_API_TOKEN=

# Comma-separated browser origins allowed to call the backend.
STORY_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Per-client story generation quota.
STORY_RATE_LIMIT_WINDOW_MS=60000
STORY_RATE_LIMIT_MAX=20
