# Anthropic API key — fallback for headless/CI use.
# In the desktop app, set this via Settings instead.
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# DEV ONLY — never set in production builds.
# When set to 1, full prompt text is stored in cleartext in the SQLite
# generation_log table instead of a SHA-256 digest. Useful for local
# debugging; must never be enabled in a shipped build.
# PERSIST_PROMPTS=1
