{
  "appId": "com.mythoswriter.app",
  "productName": "Mythos Writer",
  "directories": {
    "output": "dist-electron"
  },
  "files": [
    "out/**/*",
    "package.json"
  ],
  "asarUnpack": [
    "**/node_modules/better-sqlite3/**"
  ],
  "win": {
    "target": [
      {
        "target": "nsis",
        "arch": ["x64"]
      },
      {
        "target": "zip",
        "arch": ["x64"]
      }
    ],
    "icon": "build/icon.ico",
    "artifactName": "${productName}-${version}.${ext}",
    "signAndEditExecutable": true
  },
  "nsis": {
    "oneClick": false,
    "allowToChangeInstallationDirectory": true,
    "createDesktopShortcut": true,
    "createStartMenuShortcut": true
  },
  "_comment_mac_arch": "arm64 only for now: better-sqlite3 is a native module and cross-building x64 on the arm64 runner needs extra prebuild setup. x64/universal is a follow-up.",
  "mac": {
    "target": [
      {
        "target": "dmg",
        "arch": ["arm64"]
      }
    ],
    "category": "public.app-category.productivity",
    "artifactName": "${productName}-${version}-${arch}.${ext}"
  },
  "dmg": {
    "artifactName": "${productName}-${version}-${arch}.${ext}"
  },
  "linux": {
    "target": [
      {
        "target": "AppImage",
        "arch": ["x64"]
      }
    ],
    "artifactName": "${productName}-${version}.${ext}"
  },
  "publish": {
    "provider": "github",
    "owner": "SkyyPlayz",
    "repo": "Mythos-Writer"
  }
}
