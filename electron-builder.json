{
  "appId": "com.mythoswriter.app",
  "productName": "Mythos Writer",
  "directories": {
    "output": "dist-electron"
  },
  "files": [
    "out/**/*",
    "package.json"
  ],
  "asarUnpack": [
    "**/node_modules/better-sqlite3/**"
  ],
  "win": {
    "target": [
      {
        "target": "nsis",
        "arch": ["x64"]
      },
      {
        "target": "zip",
        "arch": ["x64"]
      }
    ],
    "icon": "build/icon.ico",
    "artifactName": "${productName}-${version}.${ext}",
    "signAndEditExecutable": true
  },
  "nsis": {
    "oneClick": false,
    "allowToChangeInstallationDirectory": true,
    "createDesktopShortcut": true,
    "createStartMenuShortcut": true
  },
  "linux": {
    "target": [
      {
        "target": "AppImage",
        "arch": ["x64"]
      }
    ],
    "artifactName": "${productName}-${version}.${ext}"
  },
  "publish": {
    "provider": "github",
    "owner": "SkyyPlayz",
    "repo": "Mythos-Writer"
  }
}
