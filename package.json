    "test:e2e:outline": "playwright test e2e/tests/outline-planning.spec.ts --reporter=list",
    "test:e2e:settings-background": "playwright test e2e/settings-background.spec.ts --reporter=list",
    "test:e2e:editor-format-bar": "playwright test e2e/editor-format-bar.spec.ts --reporter=list",
    "test:e2e:editor-page-chrome": "playwright test e2e/editor-page-chrome.spec.ts --reporter=list",
    "test:e2e:notes-parity": "playwright test e2e/notes-parity.spec.ts --reporter=list",
    "test:e2e:wiki-link-autocomplete": "playwright test e2e/tests/wiki-link-autocomplete.spec.ts --reporter=list",
    "test:e2e:mythos-migration": "playwright test e2e/mythos-migration.spec.ts --reporter=list",
    "test:e2e:archive-agent-mvp": "playwright test e2e/archive-agent-mvp.spec.ts --reporter=list",
    "test:e2e:bg-scrim-slider": "playwright test e2e/bg-scrim-slider.spec.ts --reporter=list",
    "test:e2e:cross-tab-links": "playwright test e2e/cross-tab-links.spec.ts --reporter=list",
    "test:e2e:notes-tab": "playwright test e2e/notes-tab.spec.ts --reporter=list",
    "test:e2e:readme-screenshots": "playwright test e2e/readme-screenshots.spec.ts --reporter=list",
    "test:e2e:shell-relayout-regression": "playwright test e2e/shell-relayout-regression.spec.ts --reporter=list",
    "test:e2e:story-tab-subview": "playwright test e2e/story-tab-subview.spec.ts --reporter=list",
    "test:e2e:suggestions": "playwright test e2e/suggestions.spec.ts --reporter=list",
    "test:e2e:tab-shell": "playwright test e2e/tab-shell.spec.ts --reporter=list",
    "test:e2e:auto-linker": "playwright test e2e/tests/auto-linker.spec.ts --reporter=list",
    "test:e2e:word-count": "playwright test e2e/tests/word-count.spec.ts --reporter=list",
    "test:e2e:wiki-links": "playwright test e2e/wiki-links.spec.ts --reporter=list",
    "test:e2e:accessibility-fixes-sky1362": "playwright test e2e/accessibility-fixes-sky1362.spec.ts --reporter=list",
    "test:e2e:beta-read": "playwright test e2e/beta-read.spec.ts --reporter=list",
    "test:e2e:brainstorm-wave33": "playwright test e2e/brainstorm-wave33.spec.ts --reporter=list",
    "test:e2e:custom-template-lifecycle": "playwright test e2e/custom-template-lifecycle.spec.ts --reporter=list",
    "test:e2e:icons": "playwright test e2e/icons.spec.ts --reporter=list",
    "test:e2e:keyboard-shortcuts": "playwright test e2e/keyboard-shortcuts.spec.ts --reporter=list",
    "test:e2e:onboarding-four-paths": "playwright test e2e/onboarding-four-paths.spec.ts --reporter=list",
    "test:e2e:panel-system-wave2f": "playwright test e2e/panel-system-wave2f.spec.ts --reporter=list",
    "test:e2e:proposal-card-hover": "playwright test e2e/proposal-card-hover.spec.ts --reporter=list",
    "test:e2e:provider-settings": "playwright test e2e/provider-settings.spec.ts --reporter=list",
    "test:e2e:settings-category-subnav": "playwright test e2e/settings-category-subnav.spec.ts --reporter=list",
    "test:e2e:v1-vault-migration": "playwright test e2e/v1-vault-migration.spec.ts --reporter=list",
    "test:e2e:voice-io": "playwright test e2e/voice-io.spec.ts --reporter=list",
    "test:e2e:inline-scene-rename": "playwright test e2e/tests/inline-scene-rename.spec.ts --reporter=list",
    "test:e2e:note-templates": "playwright test e2e/tests/note-templates.spec.ts --reporter=list",
    "test:e2e:scene-editor-empty-states": "playwright test e2e/tests/scene-editor-empty-states.spec.ts --reporter=list",
    "test:e2e:sky214-entity-screenshots": "playwright test e2e/tests/sky214-entity-screenshots.spec.ts --reporter=list",
    "bughunt:report": "./BugHunt-Fisher.sh --report-only",
    "preflight": "bash scripts/preflight.sh"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.11.3",
    "@playwright/test": "^1.44.0",
    "@types/pngjs": "^6.0.5",
    "electron": "^42.3.0",
    "electron-builder": "^26.8.1",
    "electron-updater": "^6.3.9",
    "electron-vite": "^5.0.0",
    "pixelmatch": "^7.2.0",
    "pngjs": "^7.0.0",
    "vite": "^6.4.2"
