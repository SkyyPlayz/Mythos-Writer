{
  "name": "mythos-writer",
  "version": "0.1.0",
  "private": true,
  "main": "out/main/main.js",
  "workspaces": [
    "frontend",
    "electron-main"
  ],
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build && electron-builder --win zip",
    "build:installer": "electron-vite build && electron-builder --win nsis",
    "dist": "electron-vite build && electron-builder --win",
    "dist:mac": "electron-vite build && electron-builder --mac dmg",
    "dist:linux": "electron-vite build && electron-builder --linux AppImage",
    "build:electron": "electron-vite build",
    "start": "electron .",
    "package": "electron-builder --win zip",
    "lint": "npm run lint -w frontend",
    "test": "npm run test -w electron-main && npm run test -w frontend",
    "typecheck": "npm run typecheck -w frontend && npm run typecheck -w electron-main"
  },
  "devDependencies": {
    "electron": "^33.2.0",
    "electron-builder": "^25.1.8",
    "electron-updater": "^6.3.9",
    "electron-vite": "^5.0.0",
    "vite": "^6.4.2"
  },
  "overrides": {
    "vite": "^6.4.2"
  }
}
