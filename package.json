{
  "name": "mythos-writer",
  "version": "0.3.0-beta.1",
  "description": "AI-powered desktop notes and writing app",
  "homepage": "https://github.com/SkyyPlayz/Mythos-Writer",
  "author": {
    "name": "SkyyPlayz",
    "email": "skylordplayz@gmail.com"
  },
  "private": true,
  "main": "out/main/main.js",
  "workspaces": [
    "frontend",
    "electron-main",
    "shared"
  ],
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build && electron-builder --win zip",
    "build:installer": "electron-vite build && electron-builder --win nsis",
    "dist": "electron-vite build && electron-builder --win",
    "dist:mac": "electron-vite build && electron-builder --mac dmg zip --publish never",
    "dist:mac:release": "electron-vite build && electron-builder --mac dmg zip",
    "dist:linux": "electron-vite build && electron-builder --linux --publish never",
    "build:electron": "electron-vite build",
    "start": "electron .",
    "package": "electron-builder --win zip",
    "lint": "npm run lint -w frontend",
    "test": "npm run test -w electron-main && npm run test -w frontend",
    "test:e2e": "playwright test e2e/ --reporter=list",
    "test:e2e:smoke": "playwright test e2e/smoke.spec.ts --reporter=list",
    "test:e2e:crud": "playwright test e2e/vault-crud.spec.ts e2e/tests/first-run-dead-end.spec.ts e2e/vault-not-found.spec.ts e2e/settings-vault-path.spec.ts e2e/tests/sky-906-default-vault-and-switcher.spec.ts e2e/navigator-popout.spec.ts --reporter=list",
    "test:e2e:draft-history": "playwright test e2e/draft-history.spec.ts --reporter=list",
    "test:e2e:brainstorm": "playwright test e2e/brainstorm.spec.ts --reporter=list",
    "test:e2e:lmp": "playwright test e2e/tests/local-model-picker.spec.ts --reporter=list",
    "test:e2e:visual-capture": "playwright test e2e/visual-capture.spec.ts --reporter=list",
    "test:e2e:writing-modes": "playwright test e2e/writing-modes.spec.ts --reporter=list",
    "test:e2e:depth-slider": "playwright test e2e/depth-slider.spec.ts --reporter=list",
    "test:e2e:writing-assistant-tips": "playwright test e2e/tests/writing-assistant-tips.spec.ts --reporter=list",
    "test:e2e:two-vault": "playwright test e2e/tests/two-vault-crud.spec.ts --reporter=list",
    "test:e2e:two-vault-firstrun": "playwright test e2e/tests/two-vault-firstrun.spec.ts --reporter=list",
    "test:e2e:onboarding": "playwright test e2e/onboarding.spec.ts --reporter=list",
    "test:e2e:onboarding-v2": "playwright test e2e/onboarding-v2.spec.ts --reporter=list",
    "test:e2e:cloud-sync": "playwright test e2e/cloud-sync.spec.ts --reporter=list",
    "test:e2e:export": "playwright test e2e/export.spec.ts --reporter=list",
    "test:e2e:versioned-drafts": "playwright test e2e/tests/sky-10-rollback.spec.ts --reporter=list",
    "test:e2e:visual-regression": "playwright test e2e/tests/visual-regression.spec.ts --reporter=list",
    "test:e2e:vault-routing": "playwright test e2e/tests/vault-routing-regression.spec.ts --reporter=list",
    "typecheck": "npm run typecheck -w frontend && npm run typecheck -w electron-main",
    "test:e2e:a11y": "playwright test e2e/a11y-focus.spec.ts e2e/settings-a11y.spec.ts --reporter=list",
    "test:e2e:entity": "playwright test e2e/entity-system.spec.ts --reporter=list",
    "test:e2e:vault-graph": "playwright test e2e/vault-graph.spec.ts --reporter=list",
    "test:e2e:vault-graph-v0": "playwright test e2e/vault-graph-v0.spec.ts --reporter=list",
    "test:e2e:entity-mention": "playwright test e2e/tests/entity-mention.spec.ts --reporter=list",
    "test:e2e:entity-creation": "playwright test e2e/entity-creation-edge-cases.spec.ts --reporter=list",
    "test:e2e:timeline": "playwright test e2e/timeline.spec.ts --reporter=list",
    "test:e2e:entries": "playwright test e2e/entries.spec.ts --reporter=list",
    "test:e2e:post-onboarding": "playwright test e2e/post-onboarding.spec.ts --reporter=list",
    "test:e2e:continuity-panel": "playwright test e2e/continuity-panel.spec.ts --reporter=list",
    "test:e2e:continuity-peek": "playwright test e2e/continuity-peek.spec.ts --reporter=list",
    "test:e2e:scene-crafter": "playwright test e2e/tests/sceneCrafter.spec.ts --reporter=list",
    "test:e2e:writing-assistant": "playwright test e2e/writing-assistant.spec.ts --reporter=list",
    "test:e2e:outline": "playwright test e2e/tests/outline-planning.spec.ts --reporter=list",
    "test:e2e:settings-background": "playwright test e2e/settings-background.spec.ts --reporter=list",
    "test:e2e:editor-format-bar": "playwright test e2e/editor-format-bar.spec.ts --reporter=list",
    "test:e2e:editor-page-chrome": "playwright test e2e/editor-page-chrome.spec.ts --reporter=list",
    "test:e2e:notes-parity": "playwright test e2e/notes-parity.spec.ts --reporter=list",
    "bughunt:report": "./BugHunt-Fisher.sh --report-only",
    "preflight": "bash scripts/preflight.sh"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.11.3",
    "@playwright/test": "^1.44.0",
    "@types/pngjs": "^6.0.5",
    "electron": "^42.3.0",
    "electron-builder": "^26.8.1",
    "electron-updater": "^6.3.9",
    "electron-vite": "^5.0.0",
    "pixelmatch": "^7.2.0",
    "pngjs": "^7.0.0",
    "vite": "^6.4.2"
  },
  "overrides": {
    "undici": "^7.28.0",
    "vite": "^6.4.2"
  }
}
