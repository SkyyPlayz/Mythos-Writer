{
  "name": "mythos-writer",
  "version": "0.1.0",
  "private": true,
  "main": "out/main/main.js",
  "workspaces": [
    "frontend",
    "electron-main"
  ],
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build && electron-builder --win zip",
    "build:installer": "electron-vite build && electron-builder --win nsis",
    "dist": "electron-vite build && electron-builder --win",
    "dist:mac": "electron-vite build && electron-builder --mac dmg zip --publish never",
    "dist:mac:release": "electron-vite build && electron-builder --mac dmg zip",
    "dist:linux": "electron-vite build && electron-builder --linux AppImage --publish never",
    "build:electron": "electron-vite build",
    "start": "electron .",
    "package": "electron-builder --win zip",
    "lint": "npm run lint -w frontend",
    "test": "npm run test -w electron-main && npm run test -w frontend",
    "test:e2e": "playwright test e2e/ --reporter=list",
    "test:e2e:smoke": "playwright test e2e/smoke.spec.ts --reporter=list",
    "test:e2e:crud": "playwright test e2e/vault-crud.spec.ts --reporter=list",
    "test:e2e:brainstorm": "playwright test e2e/brainstorm.spec.ts --reporter=list",
    "test:e2e:onboarding": "playwright test e2e/onboarding.spec.ts --reporter=list",
    "typecheck": "npm run typecheck -w frontend && npm run typecheck -w electron-main"
  },
  "devDependencies": {
    "@playwright/test": "^1.44.0",
    "electron": "^39.8.10",
    "electron-builder": "^26.8.1",
    "electron-updater": "^6.3.9",
    "electron-vite": "^5.0.0",
    "vite": "^6.4.2"
  },
  "overrides": {
    "vite": "^6.4.2"
  }
}
